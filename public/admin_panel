        const session = JSON.parse(localStorage.getItem('session_jadi'));
        if(!session || session.rolCodigo !== 'ADM') {
            alert("Acceso denegado. Solo el Administrador Maestro puede entrar.");
            window.location.href = "index.html";
        }

