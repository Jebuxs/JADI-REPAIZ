<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>J.A.D.I - Panel Maestro</title>
    <script src="https://www.gstatic.com/firebasejs/8.10.0/firebase-app.js"></script>
    <script src="https://www.gstatic.com/firebasejs/8.10.0/firebase-database.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        :root { --gold: #fbc02d; --dark: #000; --card: #111; --text: #eee; }
        body { background: var(--dark); color: var(--text); font-family: 'Segoe UI', sans-serif; margin: 0; padding: 20px; }
        
        header { display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid var(--gold); padding-bottom: 10px; margin-bottom: 30px; }
        h2 { color: var(--gold); margin: 0; text-transform: uppercase; letter-spacing: 2px; }

        /* Accesos Rápidos */
        .grid-modules { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 15px; margin-bottom: 40px; }
        .mod-btn { background: var(--card); border: 1px solid #333; color: white; padding: 20px; border-radius: 15px; cursor: pointer; text-align: center; transition: 0.3s; text-decoration: none; }
        .mod-btn:hover { border-color: var(--gold); transform: translateY(-5px); box-shadow: 0 5px 15px rgba(251, 192, 45, 0.2); }
        .mod-btn i { font-size: 2rem; display: block; margin-bottom: 10px; }
        .mod-btn.zap { color: var(--gold); }
        .mod-btn.mkt { color: #25d366; }
        .mod-btn.inv { color: #00ccff; }

        /* Tabla de Usuarios */
        .table-container { background: var(--card); border-radius: 15px; padding: 20px; border: 1px solid #222; overflow-x: auto; }
        table { width: 100%; border-collapse: collapse; margin-top: 10px; }
        th { text-align: left; color: var(--gold); padding: 12px; border-bottom: 2px solid #222; font-size: 0.9rem; }
        td { padding: 12px; border-bottom: 1px solid #222; font-size: 0.85rem; }
        
        .role-badge { padding: 4px 8px; border-radius: 5px; font-size: 0.7rem; font-weight: bold; text-transform: uppercase; }
        .bg-adm { background: #d32f2f; color: white; }
        .bg-zpt { background: #1976d2; color: white; }
        .bg-cln { background: #4caf50; color: white; }

        select { background: #222; color: white; border: 1px solid #444; padding: 5px; border-radius: 5px; cursor: pointer; }
        .btn-refresh { background: none; border: none; color: var(--gold); cursor: pointer; font-size: 1.2rem; }
    </style>
</head>
<body>

    <header>
        <h2><i class="fas fa-crown"></i> J.A.D.I MASTER ADMIN</h2>
        <button class="btn-refresh" onclick="location.reload()"><i class="fas fa-sync-alt"></i></button>
    </header>

    <div class="grid-modules">
        <a href="trabajos.html" class="mod-btn zap">
            <i class="fas fa-hammer"></i>
            <span>ZAPATERÍA</span>
        </a>
        <a href="mensajeria.html" class="mod-btn mkt">
            <i class="fab fa-whatsapp"></i>
            <span>MARKETING / ROBOT</span>
        </a>
        <a href="inventario.html" class="mod-btn inv">
            <i class="fas fa-boxes"></i>
            <span>INVENTARIO</span>
        </a>
        <div class="mod-btn" style="opacity: 0.5; cursor: not-allowed;">
            <i class="fas fa-chart-line"></i>
            <span>REPORTES (Pronto)</span>
        </div>
    </div>

    <div class="table-container">
        <h3 style="margin-top:0;"><i class="fas fa-users-cog"></i> Gestión de Personal</h3>
        <table>
            <thead>
                <tr>
                    <th>USUARIO</th>
                    <th>TELÉFONO</th>
                    <th>ROL ACTUAL</th>
                    <th>ACCIONES</th>
                </tr>
            </thead>
            <tbody id="lista-usuarios">
                </tbody>
        </table>
    </div>

    <script>
